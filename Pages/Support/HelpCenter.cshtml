@page
@{
    ViewData["Title"] = "Help Center";
}

<section class="results-header text-center">
    <div class="container">
        <h1 class="display-5 fw-bold">Help Center</h1>
        <p class="lead text-muted">Quick support for donors, recipients, and account access.</p>
    </div>
</section>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 fw-bold">Finding Blood</h2>
                    <p class="text-muted mb-3">Use the Find Blood page to filter donors by blood group, city, availability, and verification status.</p>
                    <a asp-page="/Donors/Search" class="btn btn-outline-danger btn-sm">Find Blood</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 fw-bold">Donor Accounts</h2>
                    <p class="text-muted mb-3">Register as a donor, keep your profile updated, and use your dashboard to manage availability.</p>
                    <a asp-page="/Account/RegisterDonor" class="btn btn-outline-danger btn-sm">Become a Donor</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 fw-bold">Need Support</h2>
                    <p class="text-muted mb-3">Send us a message if you need help with requests, donor details, or your account.</p>
                    <a asp-page="/Content/Contact" class="btn btn-outline-danger btn-sm">Contact Support</a>
                </div>
            </div>
        </div>
    </div>
</div>
