@page
@model Zariya.Pages.RecipientDashboardModel
@{
    ViewData["Title"] = "Recipient Dashboard";
}

<div class="container py-5">
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.PatientProfile == null)
    {
        <div class="card border-0 shadow-sm p-5 text-center">
            <i class="fas fa-user-slash fa-3x text-muted mb-3"></i>
            <h3>No Profile Found</h3>
            <p class="text-muted">We could not load your recipient details. Please contact support.</p>
        </div>
    }
    else if (Model.Tab == "settings")
    {
        @await Html.PartialAsync("_SettingsPartial")
    }
    else
    {
        <div class="row g-4">
            <!-- Left Profile Column -->
            <div class="col-lg-4">
                <!-- Profile Card -->
                <div class="card border-0 shadow-sm overflow-hidden mb-4" style="border-radius: 16px;">
                    <div class="bg-primary text-white text-center py-4 position-relative">
                        <span class="position-absolute top-0 end-0 m-3 badge bg-white text-primary fw-bold fs-6 shadow-sm">
                            @Model.PatientProfile.BloodGroup
                        </span>
                        <div class="mb-2">
                            <img src="@(string.IsNullOrEmpty(Model.PatientProfile.ProfilePhoto) ? "/images/avatar_default.jpg" : Model.PatientProfile.ProfilePhoto)" 
                                 class="rounded-circle border border-4 border-white shadow-sm" 
                                 style="width: 100px; height: 100px; object-fit: cover;" 
                                 alt="@Model.PatientProfile.FullName" 
                                 onerror="this.src='https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=150';" />
                        </div>
                        <h4 class="m-0 fw-bold">@Model.PatientProfile.FullName</h4>
                        <p class="m-0 opacity-75" style="font-size: 0.85rem;">@Model.PatientProfile.User?.Email</p>
                    </div>
                    <div class="card-body">
                        <!-- Info List -->
                        <ul class="list-group list-group-flush" style="font-size: 0.9rem;">
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="fas fa-id-card me-2 text-primary"></i> CNIC:</span>
                                <span class="fw-semibold">@Model.PatientProfile.Cnic</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="fas fa-phone me-2 text-primary"></i> Phone:</span>
                                <span class="fw-semibold">@Model.PatientProfile.Phone</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="fas fa-map-marker-alt me-2 text-primary"></i> City:</span>
                                <span class="fw-semibold">@(Model.PatientProfile.City?.CityName ?? "No City")</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="fas fa-medkit me-2 text-primary"></i> Condition:</span>
                                <span class="fw-semibold">@(Model.PatientProfile.MedicalCondition ?? "Normal")</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted"><i class="fas fa-exclamation-circle me-2 text-primary"></i> Urgency:</span>
                                @if (Model.PatientProfile.UrgencyLevel.ToLower() == "critical")
                                {
                                    <span class="badge bg-danger">Critical</span>
                                }
                                else if (Model.PatientProfile.UrgencyLevel.ToLower() == "urgent")
                                {
                                    <span class="badge bg-warning text-dark">Urgent</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Normal</span>
                                }
                            </li>
                        </ul>

                        <a href="?tab=settings" class="btn btn-outline-secondary btn-sm w-100 mt-4 @(Model.Tab == "settings" ? "active" : "")">
                            <i class="fas fa-cog me-1"></i> Settings
                        </a>
                        <button class="btn btn-outline-primary btn-sm w-100 mt-2" data-bs-toggle="modal" data-bs-target="#updatePatientProfileModal">
                            <i class="fas fa-user-edit me-1"></i> Edit Profile Details
                        </button>
                        <button type="button" class="btn btn-outline-danger btn-sm w-100 mt-2" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">
                            <i class="fas fa-triangle-exclamation me-1"></i> Delete My Account
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Requests Column -->
            <div class="col-lg-8">
                <!-- Create Blood Request Card -->
                <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="m-0 fw-bold text-dark"><i class="fas fa-plus text-primary me-2"></i> Request Blood Donation</h5>
                    </div>
                    <div class="card-body bg-light rounded-3 m-3 mt-0">
                        <form method="post" asp-page-handler="CreateRequest">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" style="font-size: 0.85rem;">Blood Group Needed</label>
                                    <select name="bloodGroupNeeded" class="form-select" required>
                                        <option value="">Select Blood Group</option>
                                        @foreach (var bg in Model.BloodGroups)
                                        {
                                            <option value="@bg" selected="@(Model.PatientProfile.BloodGroup == bg)">@bg</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" style="font-size: 0.85rem;">Urgency Level</label>
                                    <select name="urgency" class="form-select" required>
                                        <option value="normal" selected="@(Model.PatientProfile.UrgencyLevel == "normal")">Normal (Within 24-48 hours)</option>
                                        <option value="urgent" selected="@(Model.PatientProfile.UrgencyLevel == "urgent")">Urgent (Within 6-12 hours)</option>
                                        <option value="critical" selected="@(Model.PatientProfile.UrgencyLevel == "critical")">Critical (Immediate match needed)</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold" style="font-size: 0.85rem;">Message / Hospital Details</label>
                                    <textarea name="message" class="form-control" rows="2" placeholder="Describe hospital room number, patient name, and doctor contact info..." required>Urgent blood donation required for family member at local medical center.</textarea>
                                </div>
                                <div class="col-12 text-end">
                                    <button type="submit" class="btn btn-primary px-4 fw-bold"><i class="fas fa-paper-plane me-1"></i> Submit Request</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- My Requests History List -->
                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="m-0 fw-bold text-dark"><i class="fas fa-list-alt text-primary me-2"></i> My Active & Past Requests</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.MyRequests.Count == 0)
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="fas fa-notes-medical fa-3x text-muted opacity-50 mb-3"></i>
                                <h5>No Requests Created</h5>
                                <p class="mb-0">You have not posted any blood requests yet. Use the form above to submit one.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table align-middle table-hover" style="font-size: 0.9rem;">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Date & Message</th>
                                            <th>Group</th>
                                            <th>Urgency</th>
                                            <th>Status / Match Info</th>
                                            <th style="text-align: right;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var request in Model.MyRequests)
                                        {
                                            <tr>
                                                <td style="max-width: 250px;">
                                                    <div class="fw-bold" style="font-size: 0.8rem; color: #6c757d;">
                                                        @request.CreatedAt.ToString("MMM dd, yyyy - hh:mm tt")
                                                    </div>
                                                    <div class="text-truncate" title="@request.Message">@request.Message</div>
                                                </td>
                                                <td>
                                                    <span class="badge bg-primary">@request.BloodGroupNeeded</span>
                                                </td>
                                                <td>
                                                    @if (request.Urgency.ToLower() == "critical")
                                                    {
                                                        <span class="badge bg-danger">Critical</span>
                                                    }
                                                    else if (request.Urgency.ToLower() == "urgent")
                                                    {
                                                        <span class="badge bg-warning text-dark">Urgent</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-info text-dark">Normal</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (request.Status == "accepted" && request.Donor != null)
                                                    {
                                                        <div class="text-success fw-bold">
                                                            <i class="fas fa-check-circle me-1"></i> Accepted by:
                                                        </div>
                                                        <div class="fw-semibold">
                                                            <a asp-page="/Donors/Details" asp-route-id="@request.Donor.DonorId" class="text-decoration-none">@request.Donor.FullName</a>
                                                        </div>
                                                        <div class="text-muted" style="font-size: 0.8rem;"><i class="fas fa-phone me-1 text-success"></i> @request.Donor.Phone</div>
                                                        <button type="button" class="btn btn-outline-warning btn-sm mt-1" data-bs-toggle="modal" data-bs-target="#reportDonorModal-@request.RequestId">
                                                            <i class="fas fa-flag me-1"></i> Report
                                                        </button>
                                                    }
                                                    else if (request.Status == "pending")
                                                    {
                                                        <span class="badge bg-warning text-dark"><i class="fas fa-spinner fa-spin me-1"></i> Searching Donors...</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@request.Status</span>
                                                    }
                                                </td>
                                                <td style="text-align: right;">
                                                    <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#cancelRequestModal" data-request-id="@request.RequestId">
                                                        <i class="fas fa-trash-alt me-1"></i> Cancel
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Profile Modal -->
        <div class="modal fade" id="updatePatientProfileModal" tabindex="-1" aria-labelledby="updatePatientProfileModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content text-dark">
                    <form method="post" asp-page-handler="UpdateProfile">
                        <div class="modal-header">
                            <h5 class="modal-title" id="updatePatientProfileModalLabel">Update Recipient Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Phone Number</label>
                                <input type="text" name="phone" class="form-control" value="@Model.PatientProfile.Phone" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">City Location</label>
                                <select name="cityId" class="form-select" required>
                                    @foreach (var city in Model.CitiesList)
                                    {
                                        <option value="@city.CityId" selected="@(Model.PatientProfile.CityId == city.CityId)">@city.CityName, @city.Province</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Medical Condition</label>
                                <input type="text" name="medicalCondition" class="form-control" value="@Model.PatientProfile.MedicalCondition" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Urgency Level</label>
                                <select name="urgencyLevel" class="form-select" required>
                                    <option value="normal" selected="@(Model.PatientProfile.UrgencyLevel == "normal")">Normal</option>
                                    <option value="urgent" selected="@(Model.PatientProfile.UrgencyLevel == "urgent")">Urgent</option>
                                    <option value="critical" selected="@(Model.PatientProfile.UrgencyLevel == "critical")">Critical</option>
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Updates</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @foreach (var request in Model.MyRequests.Where(r => r.Status == "accepted" && r.Donor != null))
        {
            <!-- Report Donor Modal -->
            <div class="modal fade" id="reportDonorModal-@request.RequestId" tabindex="-1" aria-labelledby="reportDonorModalLabel-@request.RequestId" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow" style="border-radius:16px;">
                        <form method="post" asp-page-handler="ReportDonor">
                            <input type="hidden" name="requestId" value="@request.RequestId" />
                            <input type="hidden" name="reportedDonorId" value="@request.DonorId" />
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title text-warning" id="reportDonorModalLabel-@request.RequestId"><i class="fas fa-flag me-2"></i>Report Fake Donor</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body py-4">
                                <p class="text-muted mb-3">Reporting <strong>@request.Donor?.FullName</strong> as potentially fake. Please provide details below.</p>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Reason</label>
                                    <select name="reason" class="form-select" required>
                                        <option value="">Select a reason</option>
                                        <option value="Fake Donor">Fake Donor Profile</option>
                                        <option value="No Show">Donor Did Not Show Up</option>
                                        <option value="Harassment">Harassment or Misconduct</option>
                                        <option value="Fraud">Fraudulent Activity</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Description</label>
                                    <textarea name="description" class="form-control" rows="4" placeholder="Describe the issue in detail..." required></textarea>
                                </div>
                            </div>
                            <div class="modal-footer border-0 pt-0">
                                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-warning rounded-pill px-4">Submit Report</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }

        <!-- Cancel Request Confirmation Modal -->
        <div class="modal fade" id="cancelRequestModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow" style="border-radius:16px;">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title text-danger"><i class="fas fa-trash-alt me-2"></i>Cancel Request</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4">
                        <p class="text-muted mb-3">This will permanently delete this blood request. This <strong>cannot</strong> be undone.</p>
                        <div class="alert alert-danger">
                            <i class="fas fa-info-circle me-2"></i> Type <strong>DELETE</strong> to confirm.
                        </div>
                        <input type="text" id="cancelRequestInput" class="form-control" placeholder="Type DELETE here" autocomplete="off" />
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <form method="post" asp-page-handler="CancelRequest" id="cancelRequestForm" style="display:inline;">
                            <input type="hidden" name="requestId" id="cancelRequestId" value="" />
                            <button type="submit" class="btn btn-danger rounded-pill px-4" id="cancelRequestBtn" disabled>Delete Request</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Delete Account Confirmation Modal -->
        <div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-labelledby="deleteAccountModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow" style="border-radius:16px;">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title text-danger" id="deleteAccountModalLabel"><i class="fas fa-triangle-exclamation me-2"></i>Delete Account</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4">
                        <p class="text-muted mb-3">This action <strong>cannot</strong> be undone. All your recipient data and requests will be permanently removed.</p>
                        <div class="alert alert-danger">
                            <i class="fas fa-info-circle me-2"></i> Type <strong>DELETE</strong> to confirm.
                        </div>
                        <input type="text" id="deleteConfirmInput" class="form-control" placeholder="Type DELETE here" autocomplete="off" />
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <form method="post" asp-page-handler="DeleteAccount" id="deleteAccountForm" style="display:inline;">
                            <button type="submit" class="btn btn-danger rounded-pill px-4" id="deleteConfirmBtn" disabled>Permanently Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Cancel request modal
            var cancelModal = document.getElementById('cancelRequestModal');
            if (cancelModal) {
                cancelModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('cancelRequestId').value = button.getAttribute('data-request-id');
                });
                var input = document.getElementById('cancelRequestInput');
                var btn = document.getElementById('cancelRequestBtn');
                if (input && btn) {
                    input.addEventListener('input', function () {
                        btn.disabled = this.value !== 'DELETE';
                    });
                    cancelModal.addEventListener('hidden.bs.modal', function () {
                        input.value = '';
                        btn.disabled = true;
                    });
                }
            }

            // Delete account modal
            var delInput = document.getElementById('deleteConfirmInput');
            var delBtn = document.getElementById('deleteConfirmBtn');
            if (delInput && delBtn) {
                delInput.addEventListener('input', function () {
                    delBtn.disabled = this.value !== 'DELETE';
                });
            }
        });
    </script>
}
