@page
@{
    ViewData["Title"] = "Testimonials";
}

<div class="container py-5">
    <h1 class="fw-bold mb-3">Testimonials</h1>
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p>"Zariya helped us contact a verified donor quickly during an urgent hospital admission."</p>
                    <strong>Recipient family</strong>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p>"The dashboard made it simple to see requests matching my blood group and respond with confidence."</p>
                    <strong>Verified donor</strong>
                </div>
            </div>
        </div>
    </div>
</div>
