@page
@model AboutModel
@{
    ViewData["Title"] = "About Us";
}

<section class="results-header text-center">
    <div class="container">
        <h1 class="display-5 fw-bold">About Zariya</h1>
        <p class="lead text-muted">A bridge of life connecting donors and recipients in times of need.</p>
    </div>
</section>

<div class="container py-5">
    <div class="row g-5 align-items-center mb-5">
        <div class="col-lg-6">
            <h2 class="fw-bold text-primary-custom mb-3">Our Mission</h2>
            <p class="lead">Zariya was founded with a single mission: to ensure that no life is lost due to a lack of access to safe and timely blood transfusions.</p>
            <p class="text-muted">We leverage modern digital tools and real-time database indexing to bridge the communication gap between voluntary blood donors and medical patients or their caretakers. In critical moments, every second counts, and Zariya makes sure those seconds are saved.</p>
        </div>
        <div class="col-lg-6 text-center">
            <img src="~/images/logo.png" alt="Zariya Logo Illustration" style="max-height: 250px;" />
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 text-center" style="border-radius: var(--radius-md);">
                <div class="workflow-icon mb-3"><i class="fas fa-heart"></i></div>
                <h3 class="h5 fw-bold">Voluntary Giving</h3>
                <p class="text-muted m-0">Encouraging regular, voluntary, non-remunerated donations to build a healthy and secure national supply.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 text-center" style="border-radius: var(--radius-md);">
                <div class="workflow-icon mb-3"><i class="fas fa-user-shield"></i></div>
                <h3 class="h5 fw-bold">Verified Profiles</h3>
                <p class="text-muted m-0">Every donor's credentials and history are screened by admins to build security and trust.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 text-center" style="border-radius: var(--radius-md);">
                <div class="workflow-icon mb-3"><i class="fas fa-bolt"></i></div>
                <h3 class="h5 fw-bold">Rapid Response</h3>
                <p class="text-muted m-0">Intelligent regional and city-based search matching gets you coordinates and contacts immediately.</p>
            </div>
        </div>
    </div>
</div>
