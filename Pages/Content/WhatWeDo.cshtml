@page
@model Zariya.Pages.WhatWeDoModel
@{
    ViewData["Title"] = "What We Do - Zariya";
}
<section class="py-5 text-center" style="background: linear-gradient(135deg, #FFF5F5 0%, #FFF0F0 100%);">
    <div class="container py-4">
        <span class="badge bg-danger mb-3 px-3 py-2 text-uppercase" style="border-radius: 30px; letter-spacing: 1px; font-weight: 700; font-size: 0.75rem;">Our Purpose</span>
        <h1 class="display-4 fw-bold text-dark mb-3">Empowering Communities, Saving Lives</h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px; font-size: 1.15rem;">
            Zariya is a state-of-the-art digital portal bridging the critical gap between voluntary blood donors and recipients in Pakistan, bringing transparency, speed, and reliability when every second counts.
        </p>
    </div>
</section>
<div class="container py-5">
    <!-- Row 1: The Core Mission -->
    <div class="row g-5 align-items-center mb-5 pb-4">
        <div class="col-lg-6">
            <h2 class="fw-bold text-dark mb-4" style="font-size: 2rem; border-left: 5px solid var(--primary-color); padding-left: 15px;">A Life-Saving Matchmaking Network</h2>
            <p class="text-muted" style="line-height: 1.8;">
                In Pakistan, finding compatible blood during emergencies can be an overwhelming and stressful task. Traditional systems rely on scattered social media requests or expensive commercial dealers. Zariya is designed to eliminate this chaos.
            </p>
            <p class="text-muted" style="line-height: 1.8;">
                By utilizing a real-time searchable directory of volunteer donors segmented by city, availability, and blood group, Zariya allows patients and caretakers to immediately target the most relevant donors.
            </p>
            <div class="mt-4">
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div style="width:40px; height:40px; border-radius:50%; background:rgba(220,38,38,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="fas fa-check text-danger"></i>
                    </div>
                    <div>
                        <h4 class="h6 fw-bold text-dark mb-1">100% Voluntary & Non-Commercial</h4>
                        <p class="small text-muted mb-0">We strictly prohibit the sale of blood. Every donor is a volunteer registered to help for free.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3">
                    <div style="width:40px; height:40px; border-radius:50%; background:rgba(220,38,38,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="fas fa-shield-alt text-danger"></i>
                    </div>
                    <div>
                        <h4 class="h6 fw-bold text-dark mb-1">Verified Donor Profiles</h4>
                        <p class="small text-muted mb-0">Each donor's registration includes CNIC verification and compliance with health regulations.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="p-4" style="background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid rgba(0,0,0,0.03);">
                <h3 class="h5 fw-bold mb-4 text-center"><i class="fas fa-cogs text-danger me-2"></i>How the Portal Works</h3>
                <div class="position-relative">
                    <div style="position: absolute; left: 20px; top: 20px; bottom: 20px; width: 2px; background: #F3F4F6;"></div>

                    <div class="d-flex gap-4 mb-4 position-relative">
                        <div style="width:42px; height:42px; border-radius:50%; background:var(--primary-color); color:white; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.1rem; z-index:1; flex-shrink:0; box-shadow: 0 4px 10px rgba(220,38,38,0.3);">1</div>
                        <div>
                            <h4 class="h6 fw-bold text-dark mb-1">Search & Select</h4>
                            <p class="small text-muted mb-0">Filter donors by blood group, city, and status. View detailed profiles containing history and contact information.</p>
                        </div>
                    </div>

                    <div class="d-flex gap-4 mb-4 position-relative">
                        <div style="width:42px; height:42px; border-radius:50%; background:var(--primary-color); color:white; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.1rem; z-index:1; flex-shrink:0; box-shadow: 0 4px 10px rgba(220,38,38,0.3);">2</div>
                        <div>
                            <h4 class="h6 fw-bold text-dark mb-1">Request Submission</h4>
                            <p class="small text-muted mb-0">Recipient registers an account, logs in, and submits a blood request with urgency and hospital details.</p>
                        </div>
                    </div>
                    <div class="d-flex gap-4 position-relative">
                        <div style="width:42px; height:42px; border-radius:50%; background:var(--primary-color); color:white; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.1rem; z-index:1; flex-shrink:0; box-shadow: 0 4px 10px rgba(220,38,38,0.3);">3</div>
                        <div>
                            <h4 class="h6 fw-bold text-dark mb-1">Direct Coordination</h4>
                            <p class="small text-muted mb-0">The donor reviews the pending request on their dashboard, accepts or denies, and exchanges contacts for donation.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Stats & Achievements -->
    <div class="row g-4 text-center mb-5 pb-4">
        <div class="col-md-3 col-6">
            <div class="p-4" style="background:#FFF5F5; border-radius:16px;">
                <h3 class="display-6 fw-bold text-danger mb-1">10,000+</h3>
                <p class="text-muted small mb-0">Registered Donors</p>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="p-4" style="background:#FFF5F5; border-radius:16px;">
                <h3 class="display-6 fw-bold text-danger mb-1">2,500+</h3>
                <p class="text-muted small mb-0">Requests Fulfilled</p>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="p-4" style="background:#FFF5F5; border-radius:16px;">
                <h3 class="display-6 fw-bold text-danger mb-1">50+</h3>
                <p class="text-muted small mb-0">Cities Connected</p>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="p-4" style="background:#FFF5F5; border-radius:16px;">
                <h3 class="display-6 fw-bold text-danger mb-1">15 Mins</h3>
                <p class="text-muted small mb-0">Avg. Matching Time</p>
            </div>
        </div>
    </div>
    <!-- Advanced Features -->
    <div class="card border-0 shadow-sm p-5 mb-5" style="border-radius: var(--radius-md); background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%); color: white;">
        <div class="text-center mb-5">
            <span class="badge bg-danger mb-2">Technical Excellence</span>
            <h2 class="fw-bold text-white mb-3">Key Technical Features of Zariya</h2>
            <p class="text-muted mx-auto mb-0" style="max-width: 600px;">Zariya uses cutting-edge technologies to guarantee high uptime, instant notifications, and data integrity.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="p-4 h-100" style="background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);">
                    <i class="fas fa-bolt text-danger fa-2x mb-3"></i>
                    <h3 class="h6 fw-bold text-white">Emergency Broadcasts</h3>
                    <p class="small text-muted mb-0">Emergency blood requests trigger a platform-wide scrolling ticker, allowing any active user to respond instantly.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 h-100" style="background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);">
                    <i class="fas fa-map-marked-alt text-danger fa-2x mb-3"></i>
                    <h3 class="h6 fw-bold text-white">Location-based Matching</h3>
                    <p class="small text-muted mb-0">Donor dashboards automatically display same-city pending requests, prioritizing local and rapid response.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 h-100" style="background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.08);">
                    <i class="fas fa-star-half-alt text-danger fa-2x mb-3"></i>
                    <h3 class="h6 fw-bold text-white">Trust & Rating System</h3>
                    <p class="small text-muted mb-0">Recipients can rate donors and donors can rate recipients post-donation, maintaining a self-regulating community.</p>
                </div>
            </div>
        </div>
    </div>
</div>