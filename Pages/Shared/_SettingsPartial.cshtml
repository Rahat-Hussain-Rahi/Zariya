@{
    var role = (Model.Role as string) ?? string.Empty;
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<div class="row">
    <div class="col-md-3 col-lg-2 mb-4">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-0">
                <div class="list-group list-group-flush" style="border-radius:12px;">
                    @{
                        var allTabs = new (string id, string label, string icon, string[] roles)[]
                        {
                            ("personal", "Personal Information", "fa-user", new[]{"admin","donor","patient","recipient"}),
                            ("contact", "Contact Information", "fa-address-card", new[]{"admin","donor","patient","recipient"}),
                            ("medical", "Medical Information", "fa-notes-medical", new[]{"donor"}),
                            ("requirement", "Blood Requirement Details", "fa-hand-holding-heart", new[]{"patient","recipient"}),
                            ("availability", "Availability", "fa-clock", new[]{"donor"}),
                            ("donation-history", "Donation History", "fa-tint", new[]{"donor"}),
                            ("request-history", "Request History", "fa-clipboard-list", new[]{"patient","recipient"}),
                            ("notifications", "Notifications", "fa-bell", new[]{"admin","donor","patient","recipient"}),
                            ("privacy", "Privacy Settings", "fa-shield-alt", new[]{"admin","donor","patient","recipient"}),
                            ("security", "Account & Security", "fa-lock", new[]{"admin","donor","patient","recipient"}),
                            ("activity-logs", "Activity Logs", "fa-history", new[]{"admin"}),
                            ("permissions", "Permissions & Roles", "fa-user-shield", new[]{"admin"}),
                            ("danger", "Danger Zone", "fa-exclamation-triangle", new[]{"admin","donor","patient","recipient"}),
                        };
                    }
                    @foreach (var t in allTabs)
                    {
                        if (!t.roles.Contains(role)) continue;
                        var isActive = Model.SettingsTab == t.id;
                        <a href="@Model.SettingsNavPrefix@(t.id)"
                           class="list-group-item list-group-item-action border-0 @(isActive ? "active" : "")"
                           style="font-size:0.9rem;@(isActive ? "" : "color:#4B5563;")">
                            <i class="fas @t.icon me-2" style="width:18px;"></i> @t.label
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-9 col-lg-10">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show">@Model.SuccessMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                }
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show">@Model.ErrorMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
                }

                @switch (Model.SettingsTab)
                {
                    case "personal":
                        var pUser = Model.CurrentUser;
                        var pDonor = Model.DonorProfile;
                        var pPatient = Model.PatientProfile;
                        <h4 class="mb-4"><i class="fas fa-user me-2"></i>Personal Information</h4>
                        <form method="post" asp-page-handler="UpdatePersonalInfo">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Full Name</label>
                                    <input type="text" name="fullName" class="form-control" value="@pUser?.FullName" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" value="@pUser?.Email" readonly disabled />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Gender</label>
                                    <select name="gender" class="form-select">
                                        <option value="">-- Select --</option>
                                        <option value="Male" selected="@(pDonor?.Gender == "Male" || pPatient?.Gender == "Male")">Male</option>
                                        <option value="Female" selected="@(pDonor?.Gender == "Female" || pPatient?.Gender == "Female")">Female</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Date of Birth</label>
                                    <input type="date" name="dateOfBirth" class="form-control"
                                           value="@(pDonor?.DateOfBirth.ToString("yyyy-MM-dd") ?? pPatient?.DateOfBirth.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Blood Group</label>
                                    @if (role is "patient" or "recipient")
                                    {
                                        <select name="bloodGroup" class="form-select">
                                            <option value="">-- Select --</option>
                                            @foreach (var bg in Model.BloodGroups)
                                            {
                                                <option value="@bg" selected="@(pPatient?.BloodGroup == bg)">@bg</option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <input type="text" class="form-control" value="@(pDonor?.BloodGroup ?? "")" readonly disabled />
                                    }
                                </div>
                            </div>
                            <button type="submit" class="btn btn-danger mt-4 px-4">Save Changes</button>
                        </form>
                        break;

                    case "contact":
                        var cDonor = Model.DonorProfile;
                        var cPatient = Model.PatientProfile;
                        <h4 class="mb-4"><i class="fas fa-address-card me-2"></i>Contact Information</h4>
                        <form method="post" asp-page-handler="UpdateContact">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Phone</label>
                                    <input type="text" name="phone" class="form-control" value="@(cDonor?.Phone ?? cPatient?.Phone)" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">City</label>
                                    <select name="cityId" class="form-select">
                                        <option value="">-- Select City --</option>
                                        @foreach (var city in Model.CitiesList)
                                        {
                                            <option value="@city.CityId" selected="@(city.CityId == cDonor?.CityId || city.CityId == cPatient?.CityId)">@city.CityName</option>
                                        }
                                    </select>
                                </div>
                                @if (role == "donor")
                                {
                                    <div class="col-12">
                                        <label class="form-label">Bio</label>
                                        <textarea name="bio" class="form-control" rows="3">@cDonor?.Bio</textarea>
                                    </div>
                                }
                            </div>
                            <button type="submit" class="btn btn-danger mt-4 px-4">Save Changes</button>
                        </form>
                        break;

                    case "medical":
                        <h4 class="mb-4"><i class="fas fa-notes-medical me-2"></i>Medical Information</h4>
                        <form method="post" asp-page-handler="UpdateMedical">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">CNIC</label>
                                    <input type="text" class="form-control" value="@Model.DonorProfile?.Cnic" readonly disabled />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Blood Group</label>
                                    <input type="text" class="form-control" value="@Model.DonorProfile?.BloodGroup" readonly disabled />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Medical Notes / Bio</label>
                                    <textarea name="bio" class="form-control" rows="4">@Model.DonorProfile?.Bio</textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-danger mt-4 px-4">Save Changes</button>
                        </form>
                        break;

                    case "requirement":
                        <h4 class="mb-4"><i class="fas fa-hand-holding-heart me-2"></i>Blood Requirement Details</h4>
                        <form method="post" asp-page-handler="UpdateRequirement">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Medical Condition</label>
                                    <input type="text" name="medicalCondition" class="form-control" value="@Model.PatientProfile?.MedicalCondition" placeholder="e.g. Thalassemia, Surgery" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Urgency Level</label>
                                    <select name="urgencyLevel" class="form-select">
                                        <option value="normal" selected="@(Model.PatientProfile?.UrgencyLevel == "normal")">Normal</option>
                                        <option value="urgent" selected="@(Model.PatientProfile?.UrgencyLevel == "urgent")">Urgent</option>
                                        <option value="critical" selected="@(Model.PatientProfile?.UrgencyLevel == "critical")">Critical</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Blood Group</label>
                                    <input type="text" class="form-control" value="@Model.PatientProfile?.BloodGroup" readonly disabled />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-danger mt-4 px-4">Save Changes</button>
                        </form>
                        break;

                    case "availability":
                        <h4 class="mb-4"><i class="fas fa-clock me-2"></i>Availability</h4>
                        <p class="text-muted">Current status: <strong>@Model.DonorProfile?.Availability</strong></p>
                        <form method="post" asp-page-handler="ToggleAvailability">
                            <button type="submit" class="btn @(Model.DonorProfile?.Availability == "Available" ? "btn-warning" : "btn-success") px-4">
                                <i class="fas fa-toggle-on me-2"></i> Set as @(Model.DonorProfile?.Availability == "Available" ? "Unavailable" : "Available")
                            </button>
                        </form>
                        <hr class="my-4" />
                        <h5>Stats</h5>
                        <p>Total Donations: <strong>@Model.DonorProfile?.TotalDonations</strong></p>
                        <p>Last Donated: <strong>@Model.DonorProfile?.LastDonated?.ToString("MMM dd, yyyy") ?? "Never"</strong></p>
                        break;

                    case "donation-history":
                        <h4 class="mb-4"><i class="fas fa-tint me-2"></i>Donation History</h4>
                        @if (Model.Donations.Count == 0)
                        {
                            <p class="text-muted">No donations recorded yet.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead><tr><th>Date</th><th>Type</th><th>Patient</th><th>Hospital</th><th>Verified</th></tr></thead>
                                    <tbody>
                                        @foreach (var d in Model.Donations)
                                        {
                                            <tr>
                                                <td>@d.DonationDate.ToString("MMM dd, yyyy")</td>
                                                <td>@d.DonationType?.TypeName</td>
                                                <td>@d.Patient?.FullName ?? "N/A"</td>
                                                <td>@d.HospitalName</td>
                                                <td>@(d.IsVerified ? "Yes" : "No")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;

                    case "request-history":
                        <h4 class="mb-4"><i class="fas fa-clipboard-list me-2"></i>Request History</h4>
                        @if (Model.Requests.Count == 0)
                        {
                            <p class="text-muted">No requests made yet.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead><tr><th>Date</th><th>Blood Group</th><th>Urgency</th><th>Status</th><th>Donor</th></tr></thead>
                                    <tbody>
                                        @foreach (var r in Model.Requests)
                                        {
                                            <tr>
                                                <td>@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                                                <td>@r.BloodGroupNeeded</td>
                                                <td><span class="badge bg-@(r.Urgency == "critical" ? "danger" : r.Urgency == "urgent" ? "warning" : "info")">@r.Urgency</span></td>
                                                <td>@r.Status</td>
                                                <td>@r.Donor?.FullName ?? "Pending"</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;

                    case "notifications":
                        <h4 class="mb-4"><i class="fas fa-bell me-2"></i>Notifications</h4>
                        <p class="text-muted">Notification preferences will be available in a future update. Currently, notifications are sent in-app.</p>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="emailNotif" checked disabled />
                            <label class="form-check-label" for="emailNotif">Email notifications for new requests</label>
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="smsNotif" disabled />
                            <label class="form-check-label" for="smsNotif">SMS notifications</label>
                        </div>
                        break;

                    case "privacy":
                        <h4 class="mb-4"><i class="fas fa-shield-alt me-2"></i>Privacy Settings</h4>
                        <p class="text-muted">Privacy and profile visibility controls will be available in a future update.</p>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="profileVis" checked disabled />
                            <label class="form-check-label" for="profileVis">Show my profile to other users</label>
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="showPhone" disabled />
                            <label class="form-check-label" for="showPhone">Show my phone number</label>
                        </div>
                        break;

                    case "security":
                        <h4 class="mb-4"><i class="fas fa-lock me-2"></i>Account & Security</h4>
                        <form method="post" asp-page-handler="ChangePassword">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">Current Password</label>
                                    <input type="password" name="currentPassword" class="form-control" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">New Password</label>
                                    <input type="password" name="newPassword" class="form-control" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Confirm New Password</label>
                                    <input type="password" name="confirmPassword" class="form-control" required />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-danger mt-4 px-4">Change Password</button>
                        </form>
                        <hr class="my-4" />
                        <p>Email Verified: <strong>@(Model.CurrentUser?.IsEmailVerified == true ? "Yes" : "No")</strong></p>
                        <p>Account Status: <strong>@(Model.CurrentUser?.IsActive == true ? "Active" : "Deactivated")</strong></p>
                        <p>Last Login: <strong>@Model.CurrentUser?.LastLogin?.ToString("MMM dd, yyyy HH:mm") ?? "N/A"</strong></p>
                        break;

                    case "activity-logs":
                        <h4 class="mb-4"><i class="fas fa-history me-2"></i>Activity Logs</h4>
                        @if (Model.ActivityLogs.Count == 0)
                        {
                            <p class="text-muted">No activity logs available.</p>
                        }
                        else
                        {
                            <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
                                <table class="table table-sm table-hover">
                                    <thead><tr><th>Time</th><th>Action</th><th>Target</th><th>Details</th></tr></thead>
                                    <tbody>
                                        @foreach (var log in Model.ActivityLogs)
                                        {
                                            <tr>
                                                <td style="white-space:nowrap;">@log.CreatedAt.ToString("MMM dd HH:mm")</td>
                                                <td>@log.Action</td>
                                                <td>@log.TargetUser?.FullName ?? "N/A"</td>
                                                <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@log.Details</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;

                    case "permissions":
                        <h4 class="mb-4"><i class="fas fa-user-shield me-2"></i>Permissions & Roles</h4>
                        @if (Model.AllUsers.Count == 0)
                        {
                            <p class="text-muted">No users found.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
                                    <tbody>
                                        @foreach (var u in Model.AllUsers)
                                        {
                                            <tr>
                                                <td>@u.FullName</td>
                                                <td>@u.Email</td>
                                                <td>
                                                    <form method="post" asp-page-handler="UpdateUserRole" style="display:inline;">
                                                        <input type="hidden" name="targetUserId" value="@u.UserId" />
                                                        <select name="newRole" class="form-select form-select-sm d-inline" style="width:auto;" onchange="this.form.submit()">
                                                            <option value="admin" selected="@(u.Role.Trim().ToLower() == "admin")">Admin</option>
                                                            <option value="donor" selected="@(u.Role.Trim().ToLower() == "donor")">Donor</option>
                                                            <option value="patient" selected="@(u.Role.Trim().ToLower() == "patient")">Patient</option>
                                                        </select>
                                                    </form>
                                                </td>
                                                <td>@(u.IsActive ? "Active" : "Inactive")</td>
                                                <td>
                                                    <form method="post" asp-page-handler="ToggleUserActive" style="display:inline;">
                                                        <input type="hidden" name="targetUserId" value="@u.UserId" />
                                                        <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-warning" : "btn-success")">
                                                            @(u.IsActive ? "Deactivate" : "Activate")
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        break;

                    case "danger":
                        <h4 class="mb-4 text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Danger Zone</h4>
                        <div class="border border-danger rounded-3 p-4">
                            <h5 class="text-danger">Deactivate Account</h5>
                            <p class="text-muted">Temporarily disable your account. You can reactivate by contacting support.</p>
                            <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#settingsDeactivateModal"><i class="fas fa-pause-circle me-1"></i> Deactivate Account</button>
                        </div>
                        <div class="border border-danger rounded-3 p-4 mt-3">
                            <h5 class="text-danger">Delete Account</h5>
                            <p class="text-muted">Permanently delete your account and all associated data. This cannot be undone.</p>
                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#settingsDeleteModal"><i class="fas fa-trash me-1"></i> Delete Account</button>
                        </div>
                        <div class="border border-danger rounded-3 p-4 mt-3">
                            <h5 class="text-danger">Logout From All Devices</h5>
                            <p class="text-muted">Sign out of all active sessions.</p>
                            <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#settingsLogoutAllModal"><i class="fas fa-sign-out-alt me-1"></i> Logout All</button>
                        </div>
                        break;
                }
            </div>
        </div>
    </div>
</div>

<!-- Deactivate Confirmation Modal -->
<div class="modal fade" id="settingsDeactivateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-warning"><i class="fas fa-pause-circle me-2"></i>Deactivate Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <p class="text-muted mb-3">Your account will be <strong>deactivated</strong>. You can log in again at any time to reactivate it.</p>
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle me-2"></i> Type <strong>DEACTIVATE</strong> to confirm.
                </div>
                <input type="text" id="settingsDeactivateInput" class="form-control" placeholder="Type DEACTIVATE here" autocomplete="off" />
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="DeactivateAccount" id="settingsDeactivateForm" style="display:inline;">
                    <button type="submit" class="btn btn-warning rounded-pill px-4" id="settingsDeactivateBtn" disabled>Deactivate Account</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="settingsDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger"><i class="fas fa-trash me-2"></i>Delete Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <p class="text-muted mb-3">This action <strong>cannot</strong> be undone. All your data will be permanently removed.</p>
                <div class="alert alert-danger">
                    <i class="fas fa-info-circle me-2"></i> Type <strong>DELETE</strong> to confirm.
                </div>
                <input type="text" id="settingsDeleteInput" class="form-control" placeholder="Type DELETE here" autocomplete="off" />
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="DeleteAccount" id="settingsDeleteForm" style="display:inline;">
                    <button type="submit" class="btn btn-danger rounded-pill px-4" id="settingsDeleteBtn" disabled>Permanently Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Logout All Confirmation Modal -->
<div class="modal fade" id="settingsLogoutAllModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius:16px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-dark"><i class="fas fa-sign-out-alt me-2"></i>Logout From All Devices</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <p class="text-muted mb-3">You will be signed out of all active sessions. You will need to log in again.</p>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i> Type <strong>LOGOUT</strong> to confirm.
                </div>
                <input type="text" id="settingsLogoutInput" class="form-control" placeholder="Type LOGOUT here" autocomplete="off" />
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page="/Account/Login" asp-page-handler="Logout" id="settingsLogoutForm" style="display:inline;">
                    <button type="submit" class="btn btn-outline-danger rounded-pill px-4" id="settingsLogoutBtn" disabled>Logout All</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var setupInputBlocker = function (inputId, btnId, requiredText) {
            var input = document.getElementById(inputId);
            var btn = document.getElementById(btnId);
            if (input && btn) {
                input.addEventListener('input', function () {
                    btn.disabled = this.value !== requiredText;
                });
            }
        };
        setupInputBlocker('settingsDeleteInput', 'settingsDeleteBtn', 'DELETE');
        setupInputBlocker('settingsDeactivateInput', 'settingsDeactivateBtn', 'DEACTIVATE');
        setupInputBlocker('settingsLogoutInput', 'settingsLogoutBtn', 'LOGOUT');
    });
</script>
